{
  "name": "Sistema de Triagem Automática de Demandas",
  "nodes": [
    {
      "parameters": {
        "formTitle": "Sistema de Atendimento",
        "formDescription": "<p>Descreva sua demanda e nossa IA irá classificá-la automaticamente para o time correto.</p>",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Nome",
              "fieldName": "nome",
              "placeholder": "Seu nome completo",
              "requiredField": true
            },
            {
              "fieldLabel": "Email",
              "fieldType": "email",
              "fieldName": "email",
              "placeholder": "seu@email.com",
              "requiredField": true
            },
            {
              "fieldLabel": "Assunto",
              "fieldName": "assunto",
              "placeholder": "Ex: Problema com acesso ao sistema",
              "requiredField": true
            },
            {
              "fieldLabel": "Descrição da Demanda",
              "fieldType": "textarea",
              "fieldName": "descricao",
              "placeholder": "Descreva detalhadamente sua solicitação ou problema...",
              "requiredField": true
            }
          ]
        },
        "options": {
          "respondWithOptions": {
            "values": {
              "formSubmittedText": "✅ Sua demanda foi recebida e está sendo processada. Você receberá um retorno em breve!"
            }
          }
        }
      },
