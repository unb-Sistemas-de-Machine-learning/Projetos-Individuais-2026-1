    "Ler FAQ Sheet": { "main": [[{ "node": "FAQ para Texto", "type": "main", "index": 0 }]] },
    "FAQ para Texto": { "main": [[{ "node": "Merge Triagem e FAQ", "type": "main", "index": 1 }]] },
    "Merge Triagem e FAQ": { "main": [[{ "node": "Juntar Campos", "type": "main", "index": 0 }]] },
    "Juntar Campos": { "main": [[{ "node": "Gemini Com FAQ", "type": "main", "index": 0 }]] },
