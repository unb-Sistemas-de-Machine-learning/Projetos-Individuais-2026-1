# Chave de API do Google Gemini (usada para a análise de sentimentos com o LLM)
GEMINI_API_KEY="chave_do_gemini"

# Chave de API do YouTube Data v3 (usada para extrair os metadados da playlist)
YOUTUBE_API_KEY="chave_do_youtube"

# Chave de API do Genius (Client Access Token, usada para buscar as letras das músicas)
GENIUS_API_KEY="token_do_genius"