      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\n\nconst aluno = body.aluno || \"\";\nconst projeto = body.projeto || \"\";\nconst descricao = body.descricao_entrega || \"\";\nconst link = body.link_repositorio || \"\";\n\nconst entradaValida = descricao.trim().length >= 20;\n\nreturn [\n  {\n    json: {\n      aluno,\n      projeto,\n      descricao_entrega: descricao,\n      link_repositorio: link,\n      entrada_valida: entradaValida,\n      data_hora: new Date().toISOString()\n    }\n  }\n];"
