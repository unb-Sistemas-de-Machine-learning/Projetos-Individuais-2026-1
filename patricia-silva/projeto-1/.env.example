# Copie para .env e preencha. Use UMA das opções de LLM abaixo.

# --- Google Gemini (JSON via response_mime_type) ---
# Chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Use um ID listado no AI Studio (ex.: gemini-2.5-flash). Nomes curtos como gemini-1.5-flash podem dar 404.
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local, sem chave) ---
# GEMINI_API_KEY deve ficar vazio
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
