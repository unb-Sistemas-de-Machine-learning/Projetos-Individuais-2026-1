      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=<API_GEMINI>",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"text\": \"Use the context below to classify the article. Respond ONLY with JSON: {classification, confidence, decision, reason}\\n\\nContext:\\n{{$json.results ? $json.results.map(r => r.title + ': ' + r.summary).slice(0,3).join('\\\\n') : 'no context'}}\\n\\nTitle: {{$items('Normalize Input', 0, 0)[0].json.title}}\\nAbstract: {{$items('Normalize Input', 0, 0)[0].json.abstract}}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "id": "21cdf698-324c-439f-8280-0589dd22c70f",
      "name": "AI RAG Classification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        -848,
        -48
      ]
    },
    {
      "parameters": {
        "functionCode": "const response = $input.all()[0].json;\n\nlet content =\n  response.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n\ncontent = content.replace(/```json|```/g, '').trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  parsed = {\n    classification: 'potentially_relevant',\n    confidence: 0.5,\n    decision: 'request_human_review',\n    reason: 'Parse error'\n  };\n}\n\nlet confidence = parsed.confidence;\n\nif (typeof confidence === 'string') {\n  confidence =\n    confidence === 'high' ? 0.9 :\n    confidence === 'medium' ? 0.6 :\n    confidence === 'low' ? 0.3 : 0.5;\n}\n\nconfidence = Number(confidence ?? 0.5);\n\nconst decision =\n  confidence < 0.5 ? 'reject' :\n  confidence < 0.7 ? 'request_human_review' :\n  'store';\n\nreturn {\n  ...$items('Normalize Input', 0, 0)[0].json,\n  ...parsed,\n  confidence,\n  decision\n};"
      },
