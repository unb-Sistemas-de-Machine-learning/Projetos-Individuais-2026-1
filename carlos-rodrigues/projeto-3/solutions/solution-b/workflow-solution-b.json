        "url": "http://192.168.15.10:3000/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"q\": \"{{$json.title}} {{$json.abstract}}\", \"topK\": 3}",
        "options": {}
      },
      "id": "05312f30-2ba7-4bcf-ba5f-7ddbd572c799",
      "name": "Local Retriever",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
