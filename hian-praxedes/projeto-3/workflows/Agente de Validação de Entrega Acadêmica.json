        "jsCode": "return [\n  {\n    json: {\n      ...$json,\n      status: \"invalida\",\n      percentual_prontidao: 0,\n      itens_identificados: \"\",\n      pendencias: \"Descrição da entrega ausente ou insuficiente.\",\n      riscos: \"Não foi possível validar a entrega com as informações enviadas.\",\n      acao_recomendada: \"revisao_humana\",\n      confianca: 0,\n      justificativa: \"A entrada não possui informações suficientes para análise automática.\",\n      resultado_fluxo: \"Entrada inválida registrada para revisão humana.\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
